# Copier ce fichier en .env et renseigner les valeurs
# Ne jamais committer le fichier .env

# Clé API Google Gemini (obligatoire)
# Obtenir une clé : https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modèle Gemini à utiliser
# Options : gemini-2.5-flash | gemini-2.5-pro | gemini-2.0-flash
MODEL_NAME=gemini-2.5-flash

# Température de génération (0.0 = déterministe, 1.0 = créatif)
TEMPERATURE=0.1

# Budget maximum de tokens pour la réponse (thinking + texte visible)
# Valeur recommandée : 65536 pour des rapports complets sur 11 blocs
MAX_OUTPUT_TOKENS=65536
